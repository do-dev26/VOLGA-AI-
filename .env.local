# ── Python Backend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://your-python-backend.onrender.com

# ── Razorpay PUBLIC key (secret nahi — ye safe hai frontend mein) ───────────
# Razorpay Dashboard → Settings → API Keys → Key ID copy karo
# rzp_test_... (testing ke liye) ya rzp_live_... (production)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX

# ── Firebase Auth ───────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Claude API Proxy (app/api/proxy/route.ts ke liye) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────────────────────────────────────
# YE KABHI FRONTEND MEIN MAT DALO (secret hain):
#   RAZORPAY_KEY_SECRET     ← sirf Python backend ke .env mein
#   RAZORPAY_WEBHOOK_SECRET ← sirf Python backend ke .env mein
# ─────────────────────────────────────────────────────────────────────────────
